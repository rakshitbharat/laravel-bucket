{
    "name": "larabucket/laravel",
    "description": "LaraBucket is a self-hosted object storage solution for Laravel apps.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "LaraBucket Team",
            "email": "support@larabucket.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/database": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0",
        "illuminate/routing": "^10.0|^11.0",
        "league/flysystem": "^3.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "LaraBucket\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaraBucket\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaraBucket\\LaraBucketServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
